---
import type { SanityPostListItem } from "@lib/sanity";
import { upperHumanize, slugify } from "@lib/textConverter";
import { FaRegFolder, FaRegCalendarAlt } from "react-icons/fa";
import { formatDate } from "@lib/formatDate";

interface Props {
  entry: SanityPostListItem;
}

const { entry }: Props = Astro.props;
const { title, description, publishedAt, categories, slug } = entry;

const entryDate = publishedAt ? formatDate(publishedAt) : null;
---

<div class="h-full m-2 pl-0 bg-gradient-to-br gradient rounded-lg">
  <div class="glass h-full rounded-lg p-4 intersect:animate-fadeUp opacity-0">
    <h4 class="mb-2">
      <a href={`/blog/${slug}`}>
        {title}
      </a>
    </h4>
    <ul class="mb-2">
      {
        categories && (
          <li class="mr-0 inline-block">
            {categories.map(
              (category) =>
                category.title && (
                  <a
                    href={`/blog/categories/${category.slug ?? slugify(category.title)}`}
                  >
                    <FaRegFolder className={"ml-2 -mt-1 inline-block"} />
                    {upperHumanize(category.title)}
                  </a>
                ),
            )}
          </li>
        )
      }
      {
        entryDate && (
          <li class="mr-0 inline-block">
            <FaRegCalendarAlt className={"ml-2 -mt-1 inline-block"} />
            {entryDate}
          </li>
        )
      }
    </ul>
    {description && <p>{description}</p>}
  </div>
</div>
