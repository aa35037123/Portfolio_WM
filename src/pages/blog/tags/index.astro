---
import TaxaLayout from "@components/blog/TaxaLayout.astro";
import { getSanityPosts, getSanityTags } from "@lib/sanity";

const taxonomy = "tags";
const taxa = await getSanityTags();
const posts = await getSanityPosts();
const allTaxa = posts.flatMap((post) => post.tags ?? []);
---

<TaxaLayout taxonomy={taxonomy} taxa={taxa} allTaxa={allTaxa} />
