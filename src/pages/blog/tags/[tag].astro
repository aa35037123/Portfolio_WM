---
import TaxonLayout from "@components/blog/TaxonLayout.astro";
import { getSanityPostsByTag, getSanityTagSlugs } from "@lib/sanity";

export async function getStaticPaths() {
  return await getSanityTagSlugs();
}

const { tag } = Astro.params;
const filteredEntries = tag ? await getSanityPostsByTag(tag) : [];
---

<TaxonLayout taxon={tag ?? "Tag"} entries={filteredEntries} />
