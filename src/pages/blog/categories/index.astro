---
import TaxaLayout from "@components/blog/TaxaLayout.astro";
import { getSanityCategories } from "@lib/sanity";

const taxonomy = "categories";
const categories = await getSanityCategories();
const taxa = categories
  .map((category) => category.slug ?? category.title ?? "")
  .filter(Boolean);
const allTaxa = categories
  .flatMap((category) =>
    Array.from(
      { length: category.count },
      () => category.slug ?? category.title ?? "",
    ),
  )
  .filter(Boolean);
---

<TaxaLayout taxonomy={taxonomy} taxa={taxa} allTaxa={allTaxa} />
