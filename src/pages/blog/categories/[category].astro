---
import TaxonLayout from "@components/blog/TaxonLayout.astro";
import { getSanityCategorySlugs, getSanityPostsByCategory } from "@lib/sanity";

export async function getStaticPaths() {
  return await getSanityCategorySlugs();
}

const { category } = Astro.params;
const filteredEntries = category
  ? await getSanityPostsByCategory(category)
  : [];
---

<TaxonLayout taxon={category ?? "Category"} entries={filteredEntries} />
