---
import CollectionLayout from "@components/blog/CollectionLayout.astro";
import { getSanityCategories, getSanityPosts } from "@lib/sanity";

const { slug } = Astro.params;
const currentPageIndex = slug && !isNaN(Number(slug)) ? Number(slug) : 1;

const entries = await getSanityPosts();
const sanityCategories = await getSanityCategories();
const categories = sanityCategories
  .map((category) => category.slug ?? category.title ?? "")
  .filter(Boolean);
const allCategories = sanityCategories
  .flatMap((category) =>
    Array.from(
      { length: category.count },
      () => category.slug ?? category.title ?? "",
    ),
  )
  .filter(Boolean);

const entriesPerPage = 4;
const indexOfLastEntry = currentPageIndex * entriesPerPage;
const indexOfFirstEntry = indexOfLastEntry - entriesPerPage;
const currentEntries = entries.slice(indexOfFirstEntry, indexOfLastEntry);

const pageCount: number = Math.ceil(entries.length / entriesPerPage);

export async function getStaticPaths() {
  const entries = await getSanityPosts();
  // divisor below must equal entriesPerPage
  const pageCount = Math.ceil(entries.length / 4);
  const paths = [];

  for (let i = 1; i < pageCount; i++) {
    paths.push({
      params: {
        slug: (i + 1).toString(),
      },
    });
  }
  return paths;
}
---

<CollectionLayout
  title="Blog"
  description="Posts from Sanity"
  entries={currentEntries}
  categories={categories}
  allCategories={allCategories}
  pageIndex={currentPageIndex}
  pageCount={pageCount}
/>
